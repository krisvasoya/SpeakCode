{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SpeakCode",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.speakcode",
          "match": "(#|\\bnote:|\\bnote\\b).*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.speakcode",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.speakcode",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.speakcode",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "constant.language.boolean.speakcode",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.statement.speakcode",
          "match": "\\b(Remember|Change|Speak|Ask|If|Otherwise|While|Repeat|Perform|Give back|To perform|Finish checking|Finish looping|Finish performance)\\b"
        },
        {
          "name": "keyword.control.helper.speakcode",
          "match": "\\b(as|to|then|times|with|and|or)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.speakcode",
          "match": "\\b(plus|minus|times|divided by|modulo|opposite of)\\b"
        },
        {
          "name": "keyword.operator.comparison.speakcode",
          "match": "\\b(is same as|is different from|is above|is below|is at least|is at most|and save as)\\b"
        }
      ]
    }
  ],
  "scopeName": "source.spk"
}
